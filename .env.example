# Copy this file to .env.local and fill in your Supabase project values.
# Find these in the Supabase dashboard: Project Settings -> API.
#
# The anon (public) key is safe to expose in the client bundle — your data is
# protected by Row-Level Security, not by hiding this key. NEVER put the
# service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
